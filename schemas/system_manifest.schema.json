{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/governed-research-workspace-framework/schemas/system_manifest.schema.json",
  "title": "Governed Research System Manifest",
  "type": "object",
  "required": ["manifest_schema_version", "system_id", "system_version", "system_role", "entry_point", "supported_profiles", "project_ownership_behavior", "data_access_boundary"],
  "properties": {
    "manifest_schema_version": {"type": "integer", "const": 1},
    "system_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "system_version": {"type": "string", "minLength": 1},
    "system_role": {"type": "string", "minLength": 1},
    "entry_point": {"type": "string", "minLength": 1},
    "supported_profiles": {
      "type": "array",
      "items": {"type": "string", "enum": ["standalone", "framework_integrated", "private_lab_extended"]},
      "minItems": 1,
      "uniqueItems": true
    },
    "required_dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "optional_shared_services": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "framework_compatibility": {
      "type": "object",
      "required": ["supported_framework_versions"],
      "properties": {
        "supported_framework_versions": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "project_ownership_behavior": {"type": "string", "enum": ["primary_system", "contributing_system", "no_project_ownership"]},
    "data_access_boundary": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "supported_profiles": {
            "contains": {"const": "framework_integrated"}
          }
        }
      },
      "then": {
        "required": ["framework_compatibility"]
      }
    }
  ],
  "$defs": {
    "registeredSystem": {
      "type": "object",
      "required": ["system_id", "path", "system_version"],
      "properties": {
        "system_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "path": {"type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/]).+"},
        "system_version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
